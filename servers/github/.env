# ============================================================================
# GITHUB MCP SERVER CONFIGURATION
# ============================================================================
# Generated: 2026-04-09 17:23:14 UTC
#
# This file contains all configuration for the MCP server.
#
# IMPORTANT: Do not commit this file after adding credentials
# ============================================================================

# ============================================================================
# Authentication Credentials
# ============================================================================
# oauth2: OAuth 2.0 Authentication
# Type: OAuth 2.0 Authentication
# Flow: authorizationCode
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# OAuth2 callback port for local authorization server
# Add http://localhost:<port>/callback to your OAuth provider's redirect URIs
OAUTH2_CALLBACK_PORT=9400

# Available OAuth2 Scopes (configure only what you need):
# - repo : Full control of public and private repositories
# - repo:status : Read/write access to commit statuses
# - repo_deployment : Access to deployment statuses
# - public_repo : Read/write access to public repositories
# - repo:invite : Accept/decline repository invitations
# - security_events : Read/write access to security events in code scanning API
# - admin:repo_hook : Full access to repository hooks
# - write:repo_hook : Read/write/ping access to repository hooks
# - read:repo_hook : Read and ping access to repository hooks
# - admin:org : Full control of organizations, teams, projects, and memberships
# - write:org : Read/write access to organization membership and projects
# - read:org : Read-only access to organization membership and projects
# - admin:public_key : Fully manage public keys
# - write:public_key : Create, list, and view public keys
# - read:public_key : List and view public keys
# - admin:org_hook : Full access to organization hooks
# - gist : Write access to gists
# - notifications : Read access to notifications
# - user : Read/write access to profile info
# - read:user : Read access to user profile data
# - user:email : Read access to user email addresses
# - user:follow : Follow or unfollow users
# - project : Read/write access to user and organization projects
# - read:project : Read-only access to user and organization projects
# - delete_repo : Delete adminable repositories
# - write:packages : Upload or publish packages in GitHub Packages
# - read:packages : Download or install packages from GitHub Packages
# - delete:packages : Delete packages from GitHub Packages
# - admin:gpg_key : Fully manage GPG keys
# - write:gpg_key : Create, list, and view GPG keys
# - read:gpg_key : List and view GPG keys
# - codespace : Create and manage codespaces
# - workflow : Add and update GitHub Actions workflow files
# - read:audit_log : Read audit log data
# - read:discussion : Read team discussions
# - write:discussion : Write team discussions
# Configure required scopes as comma-separated list
# Example: OAUTH2_SCOPES=repo,repo:status,repo_deployment
OAUTH2_SCOPES=

# bearer_token: http_bearer Authentication
# Type: HTTP Bearer Token
BEARER_TOKEN=

# jwt_bearer: JWT Bearer Authentication
# Type: JWT Bearer Authentication (private key signing)
# Private key: absolute path to .pem file or inline PEM with newlines as \n
JWT_PRIVATE_KEY=
JWT_ISSUER_ID=

# Optional (leave empty if not needed)
JWT_ALGORITHM=RS256
JWT_EXPIRY=600
JWT_AUDIENCE=
JWT_KEY_ID=
# Set token exchange URL to exchange JWT for an access token instead of using it directly
JWT_TOKEN_URL=
JWT_SCOPES=

# ============================================================================
# Per-Operation URL Overrides (from OpenAPI path/operation servers)
# ============================================================================
# Some operations target different server URLs than the base URL.
# These override BASE_URL for specific tools.
SERVER_URL_UPLOAD_RELEASE_ASSET=https://uploads.github.com

# ============================================================================
# API Base URL
# ============================================================================
# Change to http://localhost:PORT if testing against a local API instance
BASE_URL=https://api.github.com

# ============================================================================
# Timeouts and Connection Pool
# ============================================================================

# HTTPX client granular timeout configuration (seconds)
# These control different phases of the HTTP request lifecycle:

# Connection establishment timeout
HTTPX_CONNECT_TIMEOUT=10.0

# Response read timeout (main bottleneck for slow APIs)
HTTPX_READ_TIMEOUT=60.0

# Request body write timeout
HTTPX_WRITE_TIMEOUT=30.0

# Connection pool acquisition timeout
HTTPX_POOL_TIMEOUT=5.0

# Overall tool execution timeout (wraps entire operation + retries)
# Should be higher than HTTPX_READ_TIMEOUT to allow completion
TOOL_EXECUTION_TIMEOUT=90.0

# Connection pool configuration
CONNECTION_POOL_SIZE=100
MAX_KEEPALIVE_CONNECTIONS=20

# ============================================================================
# Response Sanitization
# ============================================================================

# Sanitization level (controls which fields are redacted from responses)
# Values:
#   DISABLED - No sanitization (fastest, shows all data including secrets) [DEFAULT]
#   LOW      - Basic secrets (password, token, secret, private_key)
#   MEDIUM   - LOW + Auth fields (auth_token, access_token, credentials, authorization)
#   HIGH     - MEDIUM + Session/IDs (session_id, cookie, api_key, user_id, account_id, ip_address, hostname)
SANITIZATION_LEVEL=DISABLED

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (controls verbosity)
# Values: DEBUG, INFO, WARNING, ERROR
# - DEBUG: Very verbose (shows all requests, responses, internal state)
# - INFO: Standard logging (shows requests and important events) [DEFAULT]
# - WARNING: Only warnings and errors
# - ERROR: Only errors
LOG_LEVEL=INFO

# Log format (controls output structure)
# Values:
#   simple   - "INFO: Message" [DEFAULT]
#   detailed - "2025-12-22 10:30:45 INFO [request_id=abc123] Message"
LOG_FORMAT=simple

# ============================================================================
# Retry Logic Configuration
# ============================================================================
# Automatic retry for failed requests with exponential backoff

# Maximum number of retry attempts
# Recommendation: 3-5 retries for most APIs
MAX_RETRIES=3

# Exponential backoff multiplier
# Calculation: delay = base_delay * (backoff_factor ^ retry_number)
# Example with backoff_factor=2.0:
#   Retry 1: 1 second
#   Retry 2: 2 seconds
#   Retry 3: 4 seconds
#   Retry 4: 8 seconds
RETRY_BACKOFF_FACTOR=2

# ============================================================================
# Circuit Breaker Configuration
# ============================================================================
# Prevents cascading failures when upstream API is down

# Number of consecutive failures before opening circuit
# Once open, circuit breaker blocks all requests for timeout period
# Recommendation: 5-10 failures for most APIs
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Seconds to wait before attempting half-open state
# In half-open state, one request is allowed through to test recovery
# Recommendation: 60-300 seconds depending on API recovery time
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Local in-memory rate limiting (single process only)

# Maximum requests per second
# Prevents overwhelming upstream API with burst traffic
# Recommendation: Match or slightly below API's rate limit
RATE_LIMIT_REQUESTS_PER_SECOND=10

# ============================================================================
# End of Configuration
# ============================================================================
